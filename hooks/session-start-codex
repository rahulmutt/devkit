#!/usr/bin/env bash
# GENERATED by scripts/generate.ts — edit scripts/templates/hooks/session-start-codex instead
# SessionStart hook for the devkit plugin (Codex).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

bootstrap_content=$(cat "${PLUGIN_ROOT}/skills/using-devkit/SKILL.md" 2>&1 || echo "Error reading using-devkit skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have devkit skills.\n\n**Below is the full content of your 'devkit:using-devkit' skill — your introduction to using these skills. For all other skills, use the skill tool:**\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "additionalContext": "%s"\n}\n' "$session_context" | cat
exit 0
